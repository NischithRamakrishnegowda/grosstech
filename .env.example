DATABASE_URL="postgresql://user:password@localhost:5432/grosstech"
NEXTAUTH_SECRET="your-random-32-character-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# Razorpay — RAZORPAY_MODE controls behavior:
#   "mock"  → fake in-app modal, no Razorpay account needed
#   "test"  → real Razorpay modal with rzp_test_* keys
#   "live"  → real Razorpay modal with rzp_live_* keys
RAZORPAY_MODE="mock"
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET=""  # From Razorpay Dashboard > Webhooks (only needed for test/live)
# Email (Gmail SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASSWORD="your_app_password"
SMTP_FROM="Your App <your@gmail.com>"
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PHONE="+91XXXXXXXXXX"
# SMS (Fast2SMS — https://fast2sms.com)
FAST2SMS_API_KEY="your_fast2sms_api_key"
