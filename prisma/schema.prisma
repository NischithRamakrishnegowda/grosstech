generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAYMENT_HELD
  FAILED
  RELEASED_TO_SELLER
  CANCELLED
}

enum ListingSource {
  ADMIN
  SELLER
}

enum ListingStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum PriceMode {
  RETAIL
  BULK
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  phone         String?
  role          Role     @default(BUYER)
  businessName  String?
  street        String?
  city          String?
  state         String?
  pincode       String?
  upiId         String?
  accountNumber String?
  ifscCode      String?
  emailVerified Boolean  @default(false)
  phoneVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  listings               Listing[]
  ordersAsBuyer          Order[]         @relation("BuyerOrders")
  contactUnlocksAsBuyer  ContactUnlock[] @relation("BuyerUnlocks")
  contactUnlocksAsSeller ContactUnlock[] @relation("SellerUnlocks")
  otpTokens              OtpToken[]
  buyerRequests          BuyerRequest[]

  @@map("users")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  imageUrl  String?
  createdAt DateTime @default(now())

  listings Listing[]
  items    Item[]

  @@map("categories")
}

model Item {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  imageUrl  String?
  createdAt DateTime @default(now())

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  listings      Listing[]
  buyerRequests BuyerRequest[]

  @@map("items")
}

model Listing {
  id              String        @id @default(cuid())
  name            String
  brand           String?
  description     String?
  imageUrl        String?
  source          ListingSource @default(SELLER)
  isActive        Boolean       @default(true)
  status          ListingStatus @default(APPROVED)
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  seller   User   @relation(fields: [sellerId], references: [id])
  sellerId String

  item   Item?   @relation(fields: [itemId], references: [id])
  itemId String?

  priceOptions PriceOption[]
  orderItems   OrderItem[]

  @@map("listings")
}

model PriceOption {
  id     String    @id @default(cuid())
  weight String
  price  Float
  stock  Int       @default(0)
  mode   PriceMode @default(RETAIL)
  minQty Int       @default(1)

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String

  orderItems OrderItem[]

  @@map("price_options")
}

model Order {
  id                String  @id @default(cuid())
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  buyer   User   @relation("BuyerOrders", fields: [buyerId], references: [id])
  buyerId String

  subtotal    Float
  platformFee Float @default(20)
  total       Float

  status             OrderStatus @default(PENDING)
  paymentCapturedAt  DateTime?
  releaseScheduledAt DateTime?
  releasedAt         DateTime?

  shippingAddress String?
  shippingPhone   String?
  secondaryPhone  String?

  deliveryOption  String  @default("SELF_PICKUP")
  deliveryCharge  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id           String @id @default(cuid())
  quantity     Int
  priceAtOrder Float

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String

  priceOption   PriceOption @relation(fields: [priceOptionId], references: [id])
  priceOptionId String

  @@map("order_items")
}

enum OtpType {
  EMAIL_VERIFY
  PHONE_VERIFY
  PASSWORD_RESET
  LOGIN_OTP
}

enum OtpChannel {
  EMAIL
  PHONE
}

model OtpToken {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  code           String
  verifiedToken  String?
  type           OtpType
  channel        OtpChannel
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime    @default(now())

  @@map("otp_tokens")
}

model ContactUnlock {
  id                String  @id @default(cuid())
  razorpayOrderId   String? @unique
  razorpayPaymentId String?
  fee               Float   @default(10)
  isPaid            Boolean @default(false)

  buyer   User   @relation("BuyerUnlocks", fields: [buyerId], references: [id])
  buyerId String

  seller   User   @relation("SellerUnlocks", fields: [sellerId], references: [id])
  sellerId String

  unlockedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([buyerId, sellerId])
  @@map("contact_unlocks")
}

model BuyerRequest {
  id          String   @id @default(cuid())
  description String
  quantity    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  buyer   User   @relation(fields: [buyerId], references: [id])
  buyerId String

  item   Item?   @relation(fields: [itemId], references: [id])
  itemId String?

  @@map("buyer_requests")
}
